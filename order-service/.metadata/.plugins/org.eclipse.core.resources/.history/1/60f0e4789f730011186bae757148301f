package com.micro.order_service.Service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.micro.order_service.DTO.OrderResponse;
import com.micro.order_service.Entity.Order;
import com.micro.order_service.Repository.OrderRepo;

@Service
public class OrderService {

    @Autowired
    private OrderRepo repo;

    @Autowired
    private RestTemplate restTemplate;

    public OrderResponse getOrderById(Long id) {

        // 1. Get Order
        Order order = repo.findById(id)
                .orElseThrow(() -> new RuntimeException("Order not found"));

        // 2. Call Customer Service
        Customer customer = restTemplate.getForObject(
                "http://localhost:8081/customers/" + order.getCustomerId(),
                Customer.class
        );

        // 3. Build Response
        OrderResponse response = new OrderResponse();

        response.setOrderId(order.getId());
        response.setProductName(order.getProductName());
        response.setQuantity(order.getQuantity());
        response.setPrice(order.getPrice());

        response.setCustomerId(customer.getId());
        response.setCustomerName(customer.getName());
        response.setEmail(customer.getEmail());
        response.setPhone(customer.getPhone());

        return response;
    }
}