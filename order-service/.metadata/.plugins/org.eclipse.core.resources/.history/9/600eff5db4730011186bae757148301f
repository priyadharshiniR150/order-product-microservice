spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      routes:
        - id: customer-service
          uri: http://localhost:8081
          predicates:
            - Path=/api/customers/**

        - id: order-service
          uri: http://localhost:8082
          predicates:
            - Path=/api/orders/**

server:
  port: 8080