package com.micro.order_service.Service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpEntity;
import org.springframework.http.HttpHeaders;
import org.springframework.http.HttpMethod;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.micro.order_service.Entity.Order;
import com.micro.order_service.Repository.OrderRepo;
import com.micro.order_service.DTO.CustomerDto;

@Service
public class OrderService {

    @Autowired
    private OrderRepo repo;

    @Autowired
    private RestTemplate restTemplate;

    // CREATE ORDER
    public Order createOrder(Order order) {
        return repo.save(order);
    }

    // GET ALL ORDERS
    public List<Order> getAllOrders() {
        return repo.findAll();
    }

    // GET ORDER BY ID (with customer call)
    public Order getOrderById(Long id, String token) {

        Order order = repo.findById(id)
                .orElseThrow(() -> new RuntimeException("Order not found"));

        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", token);

        HttpEntity<String> entity = new HttpEntity<>(headers);

        ResponseEntity<CustomerDto> response = restTemplate.exchange(
                "http://localhost:8081/customers/" + order.getCustomerId(),
                HttpMethod.GET,
                entity,
                CustomerDto.class
        );

        CustomerDto customer = response.getBody();

        if (customer != null) {
            order.setCustomerName(customer.getName());
            order.setEmail(customer.getEmail());
            order.setPhone(customer.getPhone());
        }

        return order;
    }

    // DELETE ORDER
    public void deleteOrder(Long id) {
        repo.deleteById(id);
    }
}